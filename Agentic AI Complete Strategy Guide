                const confidence = dayType === 'festival' ? 85 : dayType === 'weekend' ? 92 : 88;
                
                output.innerHTML = `<strong>🎯 Demand Forecast for Tomorrow</strong><br><br>
                    <div style="font-size: 2.5rem; color: var(--primary-green); font-weight: bold;">₹${predicted.toLocaleString()}</div>
                    <p><strong>Predicted Revenue</strong></p><br>
                    <strong>Confidence Level:</strong> ${confidence}%<br><br>
                    <strong>📦 Recommended Inventory:</strong><br>
                    • Rice: ${dayType === 'festival' ? '50kg' : dayType === 'weekend' ? '30kg' : '20kg'}<br>
                    • Vegetables: ${dayType === 'festival' ? '40kg' : dayType === 'weekend' ? '25kg' : '15kg'}<br>
                    • Chicken: ${dayType === 'festival' ? '25kg' : dayType === 'weekend' ? '15kg' : '10kg'}<br><br>
                    <strong>👥 Recommended Staff:</strong> ${dayType === 'festival' ? '8 people' : dayType === 'weekend' ? '6 people' : '4 people'}<br><br>
                    <strong>⚠️ Alerts:</strong><br>
                    ${dayType === 'festival' ? '• Festival rush expected - prepare 3 hours early<br>• Consider pre-orders via WhatsApp' : '• Normal preparation schedule'}`;
            }, 2000);
        }

        // Smooth scroll for internal links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // Add loading animation
        window.addEventListener('load', () => {
            document.body.style.opacity = '0';
            setTimeout(() => {
                document.body.style.transition = 'opacity 0.5s';
                document.body.style.opacity = '1';
            }, 100);
        });
    </script>
</body>
</html>
